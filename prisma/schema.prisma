// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model Review {
  id          String   @id @default(cuid())
  productId   String   // Shopify product ID
  orderId     String   // Shopify order ID
  rating      Int      // 1-5 star rating
  title       String?  // Optional review title
  content     String   // Review content
  customerName String  // Name of the reviewer
  customerEmail String? // Optional email of the reviewer
  isVerified  Boolean  @default(false) // Whether the review is from a verified purchase
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  token       String   @unique // Unique token for review link

  @@index([productId])
  @@index([token])
}

